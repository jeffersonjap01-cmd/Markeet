rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function currentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && currentUser().role == role;
    }

    function isAdmin() {
      return hasRole("admin");
    }

    function isMentor() {
      return hasRole("mentor") || isAdmin();
    }

    function isNotBanned() {
      return isSignedIn() && currentUser().bannedStatus == false;
    }

    function isOnboardingActive() {
      return isSignedIn()
        && currentUser().onboardingActive == true
        && request.time < currentUser().onboardingEndDate;
    }

    function userEditableProfileFieldsOnly() {
      return request.resource.data.diff(resource.data).changedKeys()
        .hasOnly(["fullName", "bio", "profileImageURL", "fcmToken", "savedMaterials"]);
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.role == "defaultUser"
        && request.resource.data.bannedStatus == false;
      allow update: if (isOwner(uid) && userEditableProfileFieldsOnly()) || isAdmin();
      allow delete: if isAdmin();
    }

    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isNotBanned()
        && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isAdmin() || isOwner(resource.data.authorId);

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isNotBanned()
          && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isAdmin() || isOwner(resource.data.authorId);
      }

      match /likes/{uid} {
        allow read: if isSignedIn();
        allow create, delete: if isOwner(uid) && isNotBanned();
        allow update: if false;
      }
    }

    match /news/{newsId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /materials/{materialId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || isMentor();
    }

    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isNotBanned()
          && request.resource.data.senderId == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow update: if isOwner(resource.data.senderId) || isMentor();
        allow delete: if isOwner(resource.data.senderId) || isAdmin();
      }
    }

    match /reports/{reportId} {
      allow create: if isNotBanned()
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.status == "pending";
      allow read, update, delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read, update: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      allow create: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
